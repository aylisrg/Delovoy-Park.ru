{
  "colors": {
    "primary": "#16342d",
    "primary-container": "#2d4b43",
    "on-primary": "#ffffff",
    "on-primary-container": "#99bab0",
    "secondary": "#7c5730",
    "secondary-container": "#fdcb9b",
    "on-secondary": "#ffffff",
    "on-secondary-container": "#79542d",
    "tertiary": "#5c150b",
    "tertiary-container": "#7a2b1f",
    "on-tertiary": "#ffffff",
    "on-tertiary-container": "#ff9784",
    "surface": "#fcf9f8",
    "surface-dim": "#dcd9d9",
    "surface-bright": "#fcf9f8",
    "surface-container-lowest": "#ffffff",
    "surface-container-low": "#f6f3f2",
    "surface-container": "#f0eded",
    "surface-container-high": "#eae7e7",
    "surface-container-highest": "#e4e2e1",
    "surface-variant": "#e4e2e1",
    "on-surface": "#1b1c1c",
    "on-surface-variant": "#414846",
    "outline": "#717976",
    "outline-variant": "#c1c8c4",
    "error": "#ba1a1a",
    "error-container": "#ffdad6",
    "on-error": "#ffffff",
    "on-error-container": "#93000a",
    "background": "#fcf9f8",
    "on-background": "#1b1c1c",
    "inverse-surface": "#303030",
    "inverse-on-surface": "#f3f0ef",
    "inverse-primary": "#adcec3",
    "primary-fixed": "#c8eadf",
    "primary-fixed-dim": "#adcec3",
    "secondary-fixed": "#ffdcbd",
    "secondary-fixed-dim": "#eebd8e",
    "tertiary-fixed": "#ffdad4",
    "tertiary-fixed-dim": "#ffb4a7",
    "surface-tint": "#46645c",
    "on-primary-fixed": "#01201a",
    "on-primary-fixed-variant": "#2e4c44",
    "on-secondary-fixed": "#2c1600",
    "on-secondary-fixed-variant": "#61401b",
    "on-tertiary-fixed": "#400200",
    "on-tertiary-fixed-variant": "#7c2c20"
  },
  "fonts": {
    "headline": ["Newsreader", "serif"],
    "body": ["Manrope", "sans-serif"],
    "label": ["Manrope", "sans-serif"]
  },
  "borderRadius": {
    "DEFAULT": "0.125rem",
    "lg": "0.25rem",
    "xl": "0.5rem",
    "full": "0.75rem"
  },
  "animation": {
    "slow-zoom": "slow-zoom 20s ease-in-out infinite alternate",
    "float": "float 3s ease-in-out infinite",
    "mask-reveal": "mask-reveal 1.2s cubic-bezier(0.77, 0, 0.175, 1) forwards",
    "fade-up": "fade-up 0.8s cubic-bezier(0.21, 0.45, 0.32, 0.9) forwards",
    "neon-pulse": "neon-pulse 3s ease-in-out infinite",
    "button-glow": "button-glow 4s infinite"
  },
  "keyframes": {
    "slow-zoom": {
      "0%": { "transform": "scale(1)" },
      "100%": { "transform": "scale(1.1)" }
    },
    "float": {
      "0%, 100%": { "transform": "translateY(0)" },
      "50%": { "transform": "translateY(-10px)" }
    },
    "mask-reveal": {
      "0%": { "transform": "translateY(100%)", "opacity": "0" },
      "100%": { "transform": "translateY(0)", "opacity": "1" }
    },
    "fade-up": {
      "0%": { "opacity": "0", "transform": "translateY(30px)" },
      "100%": { "opacity": "1", "transform": "translateY(0)" }
    },
    "neon-pulse": {
      "0%, 100%": { "text-shadow": "0 0 0px rgba(255, 255, 255, 0)" },
      "50%": { "text-shadow": "0 0 12px rgba(173, 206, 195, 0.4)" }
    },
    "button-glow": {
      "0%, 100%": { "box-shadow": "0 0 5px rgba(22, 52, 45, 0.3)" },
      "50%": { "box-shadow": "0 0 20px rgba(22, 52, 45, 0.6)" }
    }
  }
}
